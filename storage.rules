rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidImageSize() {
      // Max 10MB for images
      return request.resource.size < 10 * 1024 * 1024;
    }

    function isValidFileSize() {
      // Max 50MB for documents/prescriptions
      return request.resource.size < 50 * 1024 * 1024;
    }

    function isImageFile() {
      return request.resource.contentType.matches('image/.*');
    }

    function isPdfFile() {
      return request.resource.contentType == 'application/pdf';
    }

    // ============================================
    // DOCTOR PROFILE PHOTOS
    // ============================================

    match /doctors/{doctorId}/profile/{fileName} {
      // Allow read by anyone
      allow read: if true;

      // Allow write only by owner, must be image, max 10MB
      allow write: if isOwner(doctorId) && isImageFile() && isValidImageSize();
    }

    match /doctorProfileImages/{doctorId}/{allPaths=**} {
      // Allow read by anyone
      allow read: if true;

      // Allow write by authenticated users (doctor uploading their own profile)
      allow write: if isAuthenticated() && isImageFile() && isValidImageSize();
    }

    // ============================================
    // CLINIC PROFILE PHOTOS
    // ============================================

    match /clinicProfileImages/{clinicId}/{allPaths=**} {
      // Allow read by anyone
      allow read: if true;

      // Allow write by authenticated users (clinic uploading their own profile)
      allow write: if isAuthenticated() && isImageFile() && isValidImageSize();
    }

    // ============================================
    // LAB IMAGES (Logo, Cover, etc.)
    // ============================================

    match /labs/{labId}/{allPaths=**} {
      // Allow read by anyone (for mini-website)
      allow read: if true;

      // Allow write only by lab owner, must be image, max 10MB
      allow write: if isOwner(labId) && isImageFile() && isValidImageSize();
    }

    // LAB RX UPLOADS — patients upload prescriptions (unauthenticated)
    match /labs/{labId}/rx-uploads/{fileName} {
      allow read: if true;
      allow create: if request.resource.size < 5 * 1024 * 1024
                    && (request.resource.contentType.matches('image/.*') || request.resource.contentType == 'application/pdf');
    }

    // LAB REPORT UPLOADS — lab-generated or lab-uploaded patient reports (PDF)
    match /labs/{labId}/reports/{bookingId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(labId)
                    && request.resource.size < 10 * 1024 * 1024
                    && request.resource.contentType == 'application/pdf';
    }

    // ============================================
    // QR CODES
    // ============================================

    match /doctors/{doctorId}/qr-codes/{fileName} {
      // Allow read by anyone (public QR codes)
      allow read: if true;

      // Allow write only by owner
      allow write: if isOwner(doctorId) && isImageFile() && isValidImageSize();
    }

    // ============================================
    // PRESCRIPTIONS (DOCTOR UPLOADS)
    // ============================================

    match /prescriptions/{patientId}/{fileName} {
      // Allow read by authenticated users
      allow read: if isAuthenticated();

      // Allow write by authenticated users, max 50MB
      allow write: if isAuthenticated() && isValidFileSize();
    }

    match /prescriptions/doctors/{doctorId}/{fileName} {
      // Allow read by authenticated users
      allow read: if isAuthenticated();

      // Allow write only by owner, max 50MB
      allow write: if isOwner(doctorId) && isValidFileSize();
    }

    // ============================================
    // PRESCRIPTIONS (PATIENT UPLOADS)
    // ============================================

    match /prescriptions/patients/{patientId}/{fileName} {
      // Allow read by authenticated users
      allow read: if isAuthenticated();

      // Allow write by authenticated users, max 50MB
      allow write: if isAuthenticated() && isValidFileSize();
    }

    // ============================================
    // PRODUCT IMAGES (E-commerce)
    // ============================================

    match /products/{doctorId}/{productId}/{fileName} {
      // Allow read by anyone
      allow read: if true;

      // Allow write only by owner, must be image, max 10MB
      allow write: if isOwner(doctorId) && isImageFile() && isValidImageSize();
    }

    // ============================================
    // PERSONALIZED TEMPLATES
    // ============================================

    match /personalized-templates/{doctorId}/{allPaths=**} {
      // Allow read by anyone (so they can be shown on the mini-website)
      allow read: if true;

      // Allow write only by owner
      allow write: if isOwner(doctorId);
    }

    // ============================================
    // CLINIC PERSONALIZED TEMPLATES
    // ============================================

    match /clinic-personalized-templates/{clinicId}/{allPaths=**} {
      // Allow read by anyone
      allow read: if true;

      // Allow write only by owner
      allow write: if isOwner(clinicId);
    }

    // ============================================
    // PARAMEDICAL TEMPLATES + CAMP BANNERS
    // ============================================

    match /paramedical-templates/{paraId}/{allPaths=**} {
      // Public read so mini-website can render
      allow read: if true;
      // Owner can write images (size + type checked)
      allow write: if isOwner(paraId) && isImageFile() && isValidImageSize();
    }

    // ============================================
    // PARAMEDICAL PROFILE PHOTOS
    // ============================================

    match /paramedical-photos/{paraId}/{allPaths=**} {
      // Public read so mini-website can render
      allow read: if true;
      // Owner only, image, size capped
      allow write: if isOwner(paraId) && isImageFile() && isValidImageSize();
    }

    // ============================================
    // LAB TEMPLATES + CAMP BANNERS
    // ============================================

    match /lab-templates/{labId}/{allPaths=**} {
      // Public read for lab mini-website
      allow read: if true;
      // Owner only
      allow write: if isOwner(labId) && isImageFile() && isValidImageSize();
    }

    // ============================================
    // CHAT ATTACHMENTS
    // ============================================

    match /chat/{chatRoomId}/{fileName} {
      // Allow read by authenticated users
      allow read: if isAuthenticated();

      // Allow write by authenticated users, max 50MB
      allow write: if isAuthenticated() && isValidFileSize();
    }

    // ============================================
    // ADMIN PROFILE PHOTOS
    // ============================================

    match /admin_profiles/{fileName} {
      // Allow read by anyone (admin panel is already protected)
      allow read: if true;

      // Allow write - admins can upload their profile photos
      allow write: if isImageFile() && isValidImageSize();
    }

    // ============================================
    // TEMPLATES (ADMIN ONLY)
    // ============================================

    match /templates/{fileName} {
      // Allow read by anyone
      allow read: if true;

      // No public writes (admin only via backend)
      allow write: if false;
    }

    // ============================================
    // VIDEOS (ADMIN ONLY)
    // ============================================

    match /videos/{fileName} {
      // Allow read by anyone
      allow read: if true;

      // No public writes (admin only via backend)
      allow write: if false;
    }

    // ============================================
    // LAB REPORTS
    // ============================================

    match /lab-reports/{doctorId}/{patientId}/{fileName} {
      // Allow read by authenticated users
      allow read: if isAuthenticated();

      // Allow write by doctor or patient, max 50MB
      allow write: if isAuthenticated() && isValidFileSize();
    }

    // ============================================
    // PROMOS (ADMIN UPLOADS)
    // ============================================

    match /promos/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && isImageFile();
    }

    // ============================================
    // ADVERTISER CAMPAIGNS
    // ============================================

    match /campaigns/{userId}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // ============================================
    // AI RX TEMP (Intermediate Uploads)
    // ============================================

    match /ai_rx_temp/{allPaths=**} {
      allow read, write: if true; // Temporarily allow all for debugging
    }

    // ============================================
    // WATERMARK LOGOS
    // ============================================

    match /watermarkLogos/{userId}/{allPaths=**} {
      // Allow read by anyone (used in PDF generation)
      allow read: if true;

      // Allow write only by owner, must be image, max 10MB
      allow write: if isOwner(userId) && isImageFile() && isValidImageSize();
    }

    // ============================================
    // HEALTH TIP IMAGES (ADMIN UPLOADS)
    // ============================================

    match /health-tips/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && isImageFile() && isValidImageSize();
    }

    // ============================================
    // CHRONIC CARE CAMP IMAGES
    // ============================================

    match /chronic-care/{doctorId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(doctorId) && isImageFile() && isValidImageSize();
    }

    // ============================================
    // DIET CHARTS
    // ============================================

    match /diet-charts/{patientId}/{fileName} {
      // Allow read by anyone (publicly accessible link for 72h)
      allow read: if true;

      // Allow write by authenticated users, max 20MB
      allow write: if isAuthenticated() && isValidFileSize();
    }

    // ============================================
    // PHARMA COMPANIES
    // ============================================

    match /pharmaCompanies/{companyId}/{allPaths=**} {
      // Allow read by anyone
      allow read: if true;

      // Allow write by authenticated pharma users for their own company logo
      allow write: if isAuthenticated() && isImageFile() && isValidImageSize();
    }

    // ============================================
    // PHARMA CME FILES (PDFs, Videos, Documents)
    // ============================================

    match /pharma/{companyId}/cme/{fileName} {
      // Allow read by anyone (shared CME content)
      allow read: if true;

      // Allow write by authenticated pharma users, max 50MB
      allow write: if isAuthenticated() && isValidFileSize();
    }

    // ============================================
    // DEFAULT DENY
    // ============================================

    // Deny access to all other files
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
