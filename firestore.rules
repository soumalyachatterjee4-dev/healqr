rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDoctor() {
      return isAuthenticated() && exists(/databases/$(database)/documents/doctors/$(request.auth.uid));
    }

    // ============================================
    // QR POOL COLLECTION
    // ============================================
    match /qrPool/{qrId} {
      // Allow read for authenticated users (admin, clinic, doctor) and unauthenticated during signup validation
      allow read: if true;

      // Allow update for:
      // 1. Admin (full access via custom claim OR admins collection)
      // 2. During clinic/doctor signup for setting pending status (unauthenticated)
      // 3. During email verification for activating QR (authenticated)
      allow update: if (isAuthenticated() && request.auth.token.admin == true) ||
                      (isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.token.email))) ||
                      (request.resource.data.status == 'pending' && request.resource.data.linkedEmail != null) ||
                      (isAuthenticated() && request.resource.data.status == 'active' && request.resource.data.linkedEmail != null);

      // Allow create for:
      // 1. Admin (full access via custom claim OR admins collection)
      // 2. Unauthenticated virtual QR generation during clinic/doctor signup
      allow create: if (isAuthenticated() && request.auth.token.admin == true) ||
                      (isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.token.email))) ||
                      (request.resource.data.qrType == 'virtual' && request.resource.data.generatedBy in ['clinic-signup', 'doctor-signup', 'self-signup', 'lab-signup', 'paramedical-signup']);

      // No deletes allowed
      allow delete: if false;
    }

    // ============================================
    // QR CODES COLLECTION (Legacy)
    // ============================================
    match /qrCodes/{qrId} {
      // Allow read for authenticated users (admin, clinic, doctor) and unauthenticated during signup validation
      allow read: if true;

      // Allow update for:
      // 1. Admin (full access via custom claim OR admins collection)
      // 2. During clinic/doctor signup for setting pending status (unauthenticated)
      // 3. During email verification for activating QR (authenticated)
      allow update: if (isAuthenticated() && request.auth.token.admin == true) ||
                      (isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.token.email))) ||
                      (request.resource.data.status == 'pending' && request.resource.data.linkedEmail != null) ||
                      (isAuthenticated() && request.resource.data.status == 'active' && request.resource.data.linkedEmail != null);

      // No deletes allowed
      allow delete: if false;
    }

    // ============================================
    // CLINICS COLLECTION
    // ============================================

    match /clinics/{clinicId} {
      // Allow read by anyone (for QR booking flow and doctor linking)
      allow read: if true;

      // Allow create by authenticated clinic owners (UID must match document ID)
      allow create: if isAuthenticated() && request.auth.uid == clinicId;

      // Allow update by:
      // 1. Clinic owner (full access)
      // 2. Doctors linking themselves (can only update linkedDoctorCodes and linkedDoctorsDetails)
      // 3. Branch location managers (email in locationEmails array)
      // 4. Any authenticated user updating only linkedDoctorCodes/linkedDoctorsDetails (for doctor-side linking)
      allow update: if isAuthenticated() && (
        request.auth.uid == clinicId ||
        (isDoctor() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['linkedDoctorCodes', 'linkedDoctorsDetails'])) ||
        (request.auth.token.email in resource.data.locationEmails) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['linkedDoctorCodes', 'linkedDoctorsDetails']))
      );

      // No deletes allowed
      allow delete: if false;

      // ============================================
      // TEMP DOCTOR ACCESS SUBCOLLECTION
      // ============================================
      match /tempDoctorAccess/{accessId} {
        // Allow read by anyone (temp doctors need to validate token/PIN without auth)
        allow read: if true;

        // Allow create/update/delete by clinic owner, branch location managers, or master access
        allow create, update, delete: if isAuthenticated() && (
          request.auth.uid == clinicId ||
          (request.auth.token.email in get(/databases/$(database)/documents/clinics/$(clinicId)).data.locationEmails) ||
          (request.auth.token.email == get(/databases/$(database)/documents/clinics/$(clinicId)).data.masterAccessEmail)
        );
      }

      // ============================================
      // SUPPORT MESSAGES SUBCOLLECTION
      // ============================================
      match /supportMessages/{messageId} {
        allow read, write: if isAuthenticated();
      }

      // ============================================
      // DOWNLOAD HISTORY SUBCOLLECTION
      // ============================================
      match /downloadHistory/{historyId} {
        allow read, write: if isAuthenticated() && (
          request.auth.uid == clinicId ||
          (request.auth.token.email in get(/databases/$(database)/documents/clinics/$(clinicId)).data.locationEmails) ||
          (request.auth.token.email == get(/databases/$(database)/documents/clinics/$(clinicId)).data.masterAccessEmail)
        );
      }

      // ============================================
      // REVENUE ENTRIES SUBCOLLECTION
      // ============================================
      match /revenueEntries/{entryId} {
        allow read, write: if isAuthenticated() && (
          request.auth.uid == clinicId ||
          (request.auth.token.email in get(/databases/$(database)/documents/clinics/$(clinicId)).data.locationEmails) ||
          (request.auth.token.email == get(/databases/$(database)/documents/clinics/$(clinicId)).data.masterAccessEmail)
        );
      }

      // ============================================
      // BILLING RECEIPTS SUBCOLLECTION
      // ============================================
      match /receipts/{receiptId} {
        allow read, write: if isAuthenticated() && (
          request.auth.uid == clinicId ||
          (request.auth.token.email in get(/databases/$(database)/documents/clinics/$(clinicId)).data.locationEmails) ||
          (request.auth.token.email == get(/databases/$(database)/documents/clinics/$(clinicId)).data.masterAccessEmail)
        );
      }

      // ============================================
      // INVENTORY SUBCOLLECTION
      // ============================================
      match /inventory/{itemId} {
        allow read, write: if isAuthenticated() && (
          request.auth.uid == clinicId ||
          (request.auth.token.email in get(/databases/$(database)/documents/clinics/$(clinicId)).data.locationEmails) ||
          (request.auth.token.email == get(/databases/$(database)/documents/clinics/$(clinicId)).data.masterAccessEmail)
        );
      }

      // ============================================
      // STOCK LOGS SUBCOLLECTION
      // ============================================
      match /stockLogs/{logId} {
        allow read, write: if isAuthenticated() && (
          request.auth.uid == clinicId ||
          (request.auth.token.email in get(/databases/$(database)/documents/clinics/$(clinicId)).data.locationEmails) ||
          (request.auth.token.email == get(/databases/$(database)/documents/clinics/$(clinicId)).data.masterAccessEmail)
        );
      }

      // ============================================
      // BROADCAST LOGS SUBCOLLECTION
      // ============================================
      match /broadcastLogs/{logId} {
        allow read, write: if isAuthenticated() && (
          request.auth.uid == clinicId ||
          (request.auth.token.email in get(/databases/$(database)/documents/clinics/$(clinicId)).data.locationEmails) ||
          (request.auth.token.email == get(/databases/$(database)/documents/clinics/$(clinicId)).data.masterAccessEmail)
        );
      }
    }

    // ============================================
    // LABS / DIAGNOSTIC CENTERS COLLECTION
    // ============================================
    match /labs/{labId} {
      // Allow read by anyone (for QR booking flow)
      allow read: if true;

      // Allow create by authenticated lab owners (UID must match document ID)
      allow create: if isAuthenticated() && request.auth.uid == labId;

      // Allow update by lab owner
      allow update: if isAuthenticated() && request.auth.uid == labId;

      // No deletes allowed
      allow delete: if false;

      // Lab assistants subcollection
      match /assistants/{assistantId} {
        allow read, write: if isAuthenticated() && request.auth.uid == labId;
      }

      // Lab support messages
      match /supportMessages/{messageId} {
        allow read, write: if isAuthenticated();
      }

      // Lab test catalog
      match /testCatalog/{testId} {
        allow read: if true;
        allow write: if isAuthenticated() && request.auth.uid == labId;
      }

      // Lab schedule slots
      match /scheduleSlots/{slotId} {
        allow read: if true;
        allow write: if isAuthenticated() && request.auth.uid == labId;
      }

      // Lab phlebotomists
      match /phlebotomists/{phlebId} {
        allow read: if true;
        allow write: if isAuthenticated() && request.auth.uid == labId;
      }

      // Lab reviews (collected from patients + self-created by lab)
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if true; // Patients can submit reviews
        allow update, delete: if isAuthenticated() && request.auth.uid == labId;
      }

      // Lab report templates (reusable test combos like FBS/PP, T3/T4/TSH)
      match /labReportTemplates/{templateId} {
        allow read, write: if isAuthenticated() && request.auth.uid == labId;
      }

      // Inventory items (reagents, kits, consumables)
      match /inventory/{itemId} {
        allow read, write: if isAuthenticated() && request.auth.uid == labId;
      }

      // Stock movement logs (credit / debit history)
      match /stockLogs/{logId} {
        allow read, write: if isAuthenticated() && request.auth.uid == labId;
      }

      // Staff members
      match /staff/{staffId} {
        allow read, write: if isAuthenticated() && request.auth.uid == labId;
      }

      // Daily attendance records
      match /attendance/{attendanceId} {
        allow read, write: if isAuthenticated() && request.auth.uid == labId;
      }

      // Monthly planner notes (tasks / events / reminders)
      match /plannerNotes/{noteId} {
        allow read, write: if isAuthenticated() && request.auth.uid == labId;
      }

      // Patient broadcast history
      match /broadcastLogs/{logId} {
        allow read, write: if isAuthenticated() && request.auth.uid == labId;
      }
    }

    // ============================================
    // PENDING SIGNUPS COLLECTION (Temporary storage before email verification)
    // ============================================

    match /pending_signups/{email} {
      // Allow anyone to create (for signup flow)
      allow create: if true;

      // Allow read by anyone (needed for email verification)
      allow read: if true;

      // Allow delete after successful verification
      allow delete: if true;

      // No updates
      allow update: if false;
    }

    // ============================================
    // PHLEBOTOMISTS COLLECTION (Top-level independent entity)
    // ============================================

    match /phlebotomists/{phlebId} {
      // Allow read for search (by phone/email/name) and profile loading
      allow read: if true;
      // Allow create during verification flow
      allow create: if isAuthenticated();
      // Allow update/delete only by owner
      allow update, delete: if isOwner(phlebId);
    }

    // ============================================
    // PENDING PHLEBO SIGNUPS COLLECTION
    // ============================================

    match /pending_phlebo_signups/{docId} {
      // Allow anyone to create (signup flow before auth)
      allow create: if true;
      // Allow read for verification
      allow read: if true;
      // Allow delete after successful verification
      allow delete: if isAuthenticated();
      // No updates
      allow update: if false;
    }

    // ============================================
    // PARAMEDICALS COLLECTION (Unified: phlebotomist, physiotherapist, nurse, wound-dresser, aaya, home-assistant)
    // ============================================

    match /paramedicals/{paraId} {
      // Allow read for search, profile loading, and public mini-website
      allow read: if true;
      // Allow create during verification flow
      allow create: if isAuthenticated();
      // Allow update/delete only by owner
      allow update, delete: if isOwner(paraId);

      // Reviews subcollection (public mini-site + owner management)
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if true; // patients leaving reviews (pre-auth booking flow)
        allow update, delete: if isOwner(paraId);
      }

      // Notifications subcollection (owner only)
      match /notifications/{notifId} {
        allow read, write: if isOwner(paraId);
      }

      // Inventory + stock movements (owner only)
      match /inventory/{itemId} {
        allow read, write: if isOwner(paraId);
      }
      match /stockLogs/{logId} {
        allow read, write: if isOwner(paraId);
      }

      // Monthly planner notes (owner only)
      match /plannerNotes/{noteId} {
        allow read, write: if isOwner(paraId);
      }

      // Patient broadcast logs (owner only)
      match /broadcastLogs/{logId} {
        allow read, write: if isOwner(paraId);
      }

      // Emergency safety: contacts + SOS logs (owner only)
      match /emergencyContacts/{contactId} {
        allow read, write: if isOwner(paraId);
      }
      match /sosLogs/{logId} {
        allow read, write: if isOwner(paraId);
      }
    }

    // ============================================
    // PARAMEDICAL RECEIPTS COLLECTION
    // ============================================

    match /paramedicalReceipts/{receiptId} {
      // Owner reads own receipts (filtered client-side by paramedicalId)
      allow read: if isAuthenticated();
      // Owner creates receipts (for their own bookings)
      allow create: if isAuthenticated()
                    && request.resource.data.paramedicalId == request.auth.uid;
      // Updates only by owner
      allow update: if isAuthenticated()
                    && resource.data.paramedicalId == request.auth.uid;
      // No deletes (audit trail)
      allow delete: if false;
    }

    // ============================================
    // PARAMEDICAL BOOKINGS COLLECTION
    // ============================================

    match /paramedicalBookings/{bookingId} {
      // Allow read for authenticated paramedical staff
      allow read: if isAuthenticated();
      // Allow create for patient booking (unauthenticated)
      allow create: if true;
      // Allow update for authenticated paramedical staff
      allow update: if isAuthenticated();
      // No deletes
      allow delete: if false;
    }

    // ============================================
    // PENDING PARAMEDICAL SIGNUPS COLLECTION
    // ============================================

    match /pending_paramedical_signups/{docId} {
      // Allow anyone to create (signup flow before auth)
      allow create: if true;
      // Allow read for verification
      allow read: if true;
      // Allow delete after successful verification
      allow delete: if isAuthenticated();
      // No updates
      allow update: if false;
    }

    // ============================================
    // DOCTORS COLLECTION
    // ============================================

    match /doctors/{doctorId} {
      // Allow read for:
      // 1. Authenticated users (own profile)
      // 2. Anyone checking if email exists during signup (query only)
      // 3. Anyone for QR booking flow (need to read doctor profile and update bookingsCount)
      // 4. Allow list operations for aggregation queries (count) on landing page
      allow read, list: if true;

      // Allow create for:
      // 1. New signups (email verification creates profile with user's UID)
      // 2. Clinics creating doctor profiles (for non-onboarded doctors)
      // 3. Branch location managers creating doctor profiles (email must be in clinic's locationEmails)
      allow create: if (isAuthenticated() && request.auth.uid == doctorId) ||
                      (request.auth != null && request.auth.token.email_verified == true && request.auth.uid == doctorId) ||
                      (isAuthenticated() && exists(/databases/$(database)/documents/clinics/$(request.auth.uid))) ||
                      (isAuthenticated() && request.resource.data.invitedBy != null &&
                       request.resource.data.invitedBy.clinicId != null &&
                       exists(/databases/$(database)/documents/clinics/$(request.resource.data.invitedBy.clinicId)) &&
                       request.auth.token.email in get(/databases/$(database)/documents/clinics/$(request.resource.data.invitedBy.clinicId)).data.locationEmails);

      // Allow update by:
      // 1. Doctor owner (full access)
      // 2. Clinics that have this doctor linked (can update chambers, linkedClinics, status)
      // 3. System updates (bookingsCount, totalQRScans, stats)
      // 4. Branch location managers (can update linkedClinics and locationId for doctor linking)
      // 5. Branch location managers (can update schedule-related fields: chambers, plannedOffPeriods, maxAdvanceBookingDays)
      allow update: if isOwner(doctorId) ||
                      (isAuthenticated() && exists(/databases/$(database)/documents/clinics/$(request.auth.uid))) ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bookingsCount', 'bookingBlocked', 'blockReason', 'subscriptionStatus', 'totalQRScans', 'lastScanAt', 'stats'])) ||
                      (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['linkedClinics', 'locationId'])) ||
                      (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['chambers', 'plannedOffPeriods', 'maxAdvanceBookingDays']));

      // No deletes allowed
      allow delete: if false;

      // ============================================
      // PLANNER SUBCOLLECTIONS
      // ============================================

      match /planner_events/{eventId} {
        allow read, write: if isOwner(doctorId);
      }

      match /planner_meta/{metaId} {
        allow read, write: if isOwner(doctorId);
      }

      // ============================================
      // NOTIFICATIONS SUBCOLLECTION
      // ============================================

      match /notifications/{notificationId} {
        allow read, write: if isOwner(doctorId);
      }

      match /usage/{usageId} {
        allow read, write: if isOwner(doctorId);
      }

      // ============================================
      // SUPPORT MESSAGES SUBCOLLECTION
      // ============================================
      match /supportMessages/{messageId} {
        allow read, write: if isAuthenticated();
      }

      // ============================================
      // RX TEMPLATES SUBCOLLECTION
      // ============================================
      match /rxTemplates/{templateId} {
        allow read, write: if isOwner(doctorId);
      }

      // ============================================
      // CHRONIC CARE PATIENTS SUBCOLLECTION
      // ============================================
      match /chronicPatients/{patientId} {
        allow read, write: if isOwner(doctorId);
      }

      // ============================================
      // REVENUE ENTRIES SUBCOLLECTION
      // ============================================
      match /revenueEntries/{entryId} {
        allow read, write: if isOwner(doctorId);
      }

      // ============================================
      // BILLING RECEIPTS SUBCOLLECTION
      // ============================================
      match /receipts/{receiptId} {
        allow read, write: if isOwner(doctorId);
      }

      // ============================================
      // INVENTORY SUBCOLLECTION
      // ============================================
      match /inventory/{itemId} {
        allow read, write: if isOwner(doctorId);
      }

      // ============================================
      // STOCK LOGS SUBCOLLECTION
      // ============================================
      match /stockLogs/{logId} {
        allow read, write: if isOwner(doctorId);
      }

      // ============================================
      // BROADCAST LOGS SUBCOLLECTION
      // ============================================
      match /broadcastLogs/{logId} {
        allow read, write: if isOwner(doctorId);
      }

      // ============================================
      // DOWNLOAD HISTORY SUBCOLLECTION
      // ============================================
      match /downloadHistory/{historyId} {
        allow read, write: if isOwner(doctorId);
      }
    }

    // ============================================
    // REFERRALS COLLECTION (Doctor-to-Doctor / Clinic)
    // ============================================
    match /referrals/{referralId} {
      // Any authenticated doctor or clinic can read/list referrals (queries filter by ID)
      allow read: if isDoctor() || (isAuthenticated() && exists(/databases/$(database)/documents/clinics/$(request.auth.uid)));
      // Any doctor or clinic can create a referral
      allow create: if isDoctor() || (isAuthenticated() && exists(/databases/$(database)/documents/clinics/$(request.auth.uid)));
      // Doctor or clinic can update status
      allow update: if isDoctor() || (isAuthenticated() && exists(/databases/$(database)/documents/clinics/$(request.auth.uid)));
      allow delete: if false;
    }

    // ============================================
    // SCHEDULES COLLECTION (Doctor Schedule Settings)
    // ============================================

    match /schedules/{doctorId} {
      // Allow read by anyone (needed for QR booking flow to check doctor availability)
      allow read: if true;

      // Allow create/update by doctor owner only
      allow create, update: if isOwner(doctorId);

      // No deletes allowed
      allow delete: if false;
    }

    // ============================================
    // CLINIC SCHEDULES COLLECTION (Clinic-Wide Schedule Settings)
    // ============================================

    match /clinicSchedules/{clinicId} {
      // Allow read by anyone (needed for QR booking flow to check clinic availability)
      allow read: if true;

      // Allow create/update by clinic owner only
      allow create, update: if isOwner(clinicId);

      // No deletes allowed
      allow delete: if false;
    }

    // ============================================
    // PATIENTS COLLECTION
    // ============================================

    match /patients/{patientId} {
      // Allow read by authenticated users
      allow read: if isAuthenticated();

      // Allow create/update by authenticated users
      allow create, update: if isAuthenticated();

      // No deletes allowed
      allow delete: if false;

      // ============================================
      // SUPPORT MESSAGES SUBCOLLECTION
      // ============================================
      match /supportMessages/{messageId} {
        allow read, write: if isAuthenticated();
      }
    }

    // ============================================
    // BOOKINGS COLLECTION
    // ============================================

    match /bookings/{bookingId} {
      // Allow read by anyone (needed for QR booking flow to check existing bookings)
      allow read: if true;

      // Allow create by anyone (for QR code bookings by patients)
      allow create: if true;

      // Allow update by:
      // 1. Authenticated doctors who own the booking
      // 2. Any authenticated user (covers assistants using doctor's session via localStorage)
      // 3. Anyone for specific fields that patients/system can update
      allow update: if true; // Temporarily open for debugging - will restrict after testing

      // No deletes allowed
      allow delete: if false;
    }

    // ============================================
    // MR BOOKINGS COLLECTION
    // ============================================

    match /mrBookings/{bookingId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // ============================================
    // APPOINTMENTS COLLECTION (Alternative naming for bookings)
    // ============================================

    match /appointments/{appointmentId} {
      // Allow read/list by anyone (for aggregation queries and appointment lookups)
      allow read, list: if true;

      // Allow create by anyone (for QR code bookings by patients)
      allow create: if true;

      // Allow update by authenticated users
      allow update: if true;

      // No deletes allowed
      allow delete: if false;
    }

    // ============================================
    // TRANSACTIONS COLLECTION
    // ============================================

    match /transactions/{transactionId} {
      // Allow read by authenticated users (includes admin panel)
      allow read: if isAuthenticated();

      // Allow create by authenticated users
      allow create: if isAuthenticated();

      // No updates or deletes
      allow update, delete: if false;
    }

    // ============================================
    // NOTIFICATIONS COLLECTION
    // ============================================

    match /notifications/{notificationId} {
      // Allow read only by the recipient OR the doctor who created it
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.recipientId ||
        request.auth.uid == resource.data.doctorId
      );

      // Allow create by authenticated users (doctors creating patient notifications)
      allow create: if isAuthenticated();

      // Allow update by authenticated users (for marking as delivered/read)
      allow update: if isAuthenticated();

      // Allow delete by doctor who created it
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.doctorId;
    }

    // ============================================
    // PATIENT NOTIFICATIONS COLLECTION (120-day stored notifications)
    // ============================================

    match /patient_notifications/{notificationId} {
      // Allow patients to read their own notifications (by phone number match)
      allow read: if true; // Open for now since we match by patientPhone field

      // Allow doctors/system to create notifications
      allow create: if true;

      // Allow patients to update (mark as read)
      allow update: if true;

      // Auto-cleanup handled by service, but allow deletion
      allow delete: if true;
    }

    // ============================================
    // NOTIFICATION QUEUE COLLECTION (FCM notifications)
    // ============================================

    match /patientFCMTokens/{phone} {
      // Allow read/write for token registration (called from client)
      allow read, write: if true;
    }

    // ============================================
    // FCM TOKENS COLLECTION (New unified token storage)
    // ============================================

    match /fcmTokens/{userId} {
      // Allow anyone to write their own token (needed for notification setup)
      allow read, write: if true;
    }

    // ============================================
    // ASSISTANTS COLLECTION
    // ============================================

    match /assistants/{assistantId} {
      // Allow anyone to read for magic link verification (token-based)
      // This is needed because verification happens before authentication
      allow read: if true;

      // Allow doctor to write their own assistants
      allow write: if isAuthenticated() && request.auth.uid == resource.data.doctorId;

      // Allow doctor to create new assistants
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.doctorId;
    }

    // ============================================
    // ASSISTANT HISTORY COLLECTION
    // ============================================

    match /assistantHistory/{historyId} {
      // Allow doctor to read their assistant history
      allow read: if isAuthenticated() && request.auth.uid == resource.data.doctorId;

      // Allow system to create history entries (write-only for backend)
      allow create: if isAuthenticated();

      // No updates or deletes
      allow update, delete: if false;
    }

    // ============================================
    // NOTIFICATION QUEUE COLLECTION
    // ============================================

    match /notificationQueue/{notificationId} {
      // Allow read by authenticated doctors
      allow read: if isAuthenticated() && isDoctor();

      // Allow create by authenticated doctors (for queuing patient notifications)
      allow create: if isAuthenticated() && isDoctor();

      // Allow update by authenticated users (for status updates by Cloud Functions)
      allow update: if isAuthenticated();

      // Allow delete by authenticated doctors
      allow delete: if isAuthenticated() && isDoctor();
    }

    // ============================================
    // SCHEDULED NOTIFICATIONS COLLECTION
    // ============================================

    match /scheduledNotifications/{notificationId} {
      // Allow read by authenticated doctors
      allow read: if isAuthenticated() && isDoctor();

      // Allow create by authenticated doctors
      allow create: if isAuthenticated() && isDoctor();

      // Allow update by authenticated users (for cancellation/status updates)
      allow update: if isAuthenticated();

      // Allow delete by authenticated doctors
      allow delete: if isAuthenticated() && isDoctor();
    }

    // ============================================
    // CHAT ROOMS COLLECTION
    // ============================================

    match /chatRooms/{chatRoomId} {
      // Allow read if user is participant
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.doctorId ||
        request.auth.uid == resource.data.patientId
      );

      // Allow create by authenticated users
      allow create: if isAuthenticated();

      // Allow update by participants
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.doctorId ||
        request.auth.uid == resource.data.patientId
      );

      // No deletes
      allow delete: if false;
    }

    // ============================================
    // CHAT MESSAGES COLLECTION
    // ============================================

    match /chatMessages/{messageId} {
      // Allow read if user is sender or in the chat room
      allow read: if isAuthenticated();

      // Allow create by authenticated users
      allow create: if isAuthenticated();

      // Allow update only by sender (for marking as read)
      allow update: if isAuthenticated() && request.auth.uid == resource.data.senderId;

      // No deletes
      allow delete: if false;
    }

    // ============================================
    // REVIEWS COLLECTION
    // ============================================

    match /reviews/{reviewId} {
      // Allow read by anyone (public reviews + landing page testimonials)
      allow read: if true;

      // Allow create by authenticated users
      allow create: if isAuthenticated();

      // Allow update by authenticated users (admin uploads to landing, doctor responds)
      allow update: if isAuthenticated();

      // No deletes
      allow delete: if false;
    }

    // ============================================
    // DISCOUNT CARDS COLLECTION
    // ============================================

    match /discountCards/{cardId} {
      // Allow read by authenticated users (doctors can check validity)
      allow read: if isAuthenticated();

      // Allow admin to create/update/delete (admin email: healqr@gmail.com)
      // In production, add proper admin role check
      allow create, update, delete: if isAuthenticated();
    }

    // ============================================
    // PRODUCTS COLLECTION (E-commerce)
    // ============================================

    match /products/{productId} {
      // Allow read by anyone
      allow read: if true;

      // Allow create/update only by the product owner (doctor)
      allow create, update: if isAuthenticated() && request.auth.uid == request.resource.data.doctorId;

      // Allow delete only by owner
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.doctorId;
    }

    // ============================================
    // ORDERS COLLECTION (E-commerce)
    // ============================================

    match /orders/{orderId} {
      // Allow read by doctor or customer
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.doctorId ||
        request.auth.uid == resource.data.customerId
      );

      // Allow create by authenticated users
      allow create: if isAuthenticated();

      // Allow update only by doctor
      allow update: if isAuthenticated() && request.auth.uid == resource.data.doctorId;

      // No deletes
      allow delete: if false;
    }

    // ============================================
    // PRESCRIPTIONS COLLECTION
    // ============================================

    match /prescriptions/{prescriptionId} {
      // Allow read by doctor or patient
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.doctorId ||
        request.auth.uid == resource.data.patientId
      );

      // Allow create by authenticated users
      allow create: if isAuthenticated();

      // Allow update only by doctor
      allow update: if isAuthenticated() && request.auth.uid == resource.data.doctorId;

      // No deletes
      allow delete: if false;
    }

    // ============================================
    // VIDEO CONSULTATIONS COLLECTION
    // ============================================

    match /videoConsultations/{consultationId} {
      // Allow read by doctor or patient
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.doctorId ||
        request.auth.uid == resource.data.patientId
      );

      // Allow create/update by doctor
      allow create, update: if isAuthenticated() && isDoctor();

      // No deletes
      allow delete: if false;
    }

    // ============================================
    // LAB REFERRALS COLLECTION
    // ============================================

    match /labReferrals/{referralId} {
      // Allow read by doctor or patient
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.doctorId ||
        request.auth.uid == resource.data.patientId
      );

      // Allow create/update only by doctor
      allow create, update: if isAuthenticated() && isDoctor();

      // No deletes
      allow delete: if false;
    }

    // ============================================
    // TEMPLATES COLLECTION
    // ============================================

    match /templates/{templateId} {
      // Allow read by anyone
      allow read: if true;

      // Allow create/update/delete only by admins (handled server-side)
      allow write: if false;
    }

    // ============================================
    // VIDEOS COLLECTION
    // ============================================

    match /videos/{videoId} {
      // Allow read by anyone
      allow read: if true;

      // Allow create/update/delete only by admins (handled server-side)
      allow write: if false;
    }

    // ============================================
    // ASSISTANTS COLLECTION
    // ============================================

    match /assistants/{assistantId} {
      // Allow read by the doctor or assistant themselves
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.doctorId ||
        request.auth.uid == assistantId
      );

      // Allow create/update/delete only by the doctor
      allow write: if isAuthenticated() && request.auth.uid == resource.data.doctorId;
    }

    // ============================================
    // USERS COLLECTION (Unified user storage)
    // ============================================

    match /users/{userId} {
      // Allow anyone to read/list for aggregation queries and user lookups
      allow read, list: if true;

      // Allow authenticated users to write their own data
      allow create, update: if isAuthenticated() && request.auth.uid == userId;

      // No deletes allowed
      allow delete: if false;
    }

    // ============================================
    // ADMINS COLLECTION (New centralized admin authorization)
    // ============================================

    match /admins/{adminEmail} {
      // Allow public read for login verification (before authentication)
      // This is safe because we only store email and authorization flag
      allow read: if true;

      // Allow existing admins to add/remove partner admins
      allow write: if isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));

      // Allow super admin (from adminProfiles) to bootstrap the first partner
      allow create: if isAuthenticated() && exists(/databases/$(database)/documents/adminProfiles/super_admin)
        && get(/databases/$(database)/documents/adminProfiles/super_admin).data.email == request.auth.token.email;
    }

    // ============================================
    // ADMIN PROFILES COLLECTION (Legacy)
    // ============================================

    match /adminProfiles/{profileId} {
      // Allow public read (admin panel access is already controlled by email)
      allow read: if true;

      // Allow anyone to write (admin panel is protected by email verification)
      // Only super_admin profile can be created/updated
      allow write: if profileId == 'super_admin';
    }

    // ============================================
    // ADMIN LOGS COLLECTION
    // ============================================

    match /adminLogs/{logId} {
      // Only admins can read/write (handled server-side)
      allow read, write: if false;
    }

    // ============================================
    // PLATFORM ANALYTICS COLLECTION
    // ============================================

    match /platformAnalytics/{analyticsId} {
      // Only admins can read/write (handled server-side)
      allow read, write: if false;
    }

    // ============================================
    // SCHEDULED TASKS COLLECTION
    // ============================================

    match /scheduledTasks/{taskId} {
      // System-only collection (Cloud Functions)
      allow read, write: if false;
    }

    // ============================================
    // QR SCANS COLLECTION (Analytics)
    // ============================================

    match /qr_scans/{scanId} {
      // Allow anyone to create (for tracking QR scans)
      allow create: if true;

      // Allow doctors to read their own scans for analytics
      allow read: if isAuthenticated();

      // No updates or deletes
      allow update, delete: if false;
    }

    match /clinic_qr_scans/{scanId} {
      allow create: if true;
      allow read: if isAuthenticated();
      allow update, delete: if false;
    }

    match /lab_qr_scans/{scanId} {
      allow create: if true;
      allow read: if isAuthenticated();
      allow update, delete: if false;
    }

    // ============================================
    // LAB BOOKINGS COLLECTION
    // ============================================
    match /labBookings/{bookingId} {
      // Anyone can create a booking (patient-facing, no auth required)
      allow create: if true;

      // Authenticated users can read (lab owners read their bookings, patients read theirs)
      allow read: if true;

      // Lab owners can update status (approve, reject, complete)
      allow update: if isAuthenticated();

      // No deletes
      allow delete: if false;
    }

    // ============================================
    // NOTIFICATION SUBSCRIPTIONS COLLECTION
    // ============================================

    match /patientNotificationSubscriptions/{phone} {
      // Allow anyone to read (for sending notifications)
      allow read: if true;

      // Allow anyone to create/update (when patient consents)
      allow create, update: if true;

      // No deletes
      allow delete: if false;
    }

    // ============================================
    // PWA PUSH NOTIFICATIONS
    // ============================================

    match /patientNotifications/{notificationId} {
      // Allow anyone to read (patients viewing their notifications)
      allow read: if true;

      // Allow anyone to create (Cloud Functions + test page)
      allow create: if true;

      // Allow anyone to update (for marking as read)
      allow update: if true;

      // No deletes
      allow delete: if false;
    }

    match /notificationSubscribers/{subscriberId} {
      // Allow anyone to read (for checking subscription status)
      allow read: if true;

      // Allow anyone to create/update (when patient consents)
      allow create, update: if true;

      // No deletes
      allow delete: if false;
    }

    match /advertisements/{adId} {
      // Allow anyone to read (for displaying ads in notifications)
      allow read: if true;

      // Allow anyone to create/update (for testing, will restrict to admin later)
      allow create, update: if true;

      // Allow authenticated users to delete
      allow delete: if isAuthenticated();
    }

    // ============================================
    // SCHEDULED FOLLOW-UPS COLLECTION
    // ============================================

    match /scheduledFollowUps/{followUpId} {
      // Allow read by authenticated doctors
      allow read: if isAuthenticated();

      // Allow create by authenticated doctors (for scheduling follow-ups)
      allow create: if isAuthenticated();

      // Allow update by authenticated doctors or system (for marking as sent/failed)
      allow update: if isAuthenticated();

      // Allow delete by authenticated doctors
      allow delete: if isAuthenticated();
    }

    // ============================================
    // SUPPORT REQUESTS COLLECTION
    // ============================================

    match /supportRequests/{requestId} {
      // Allow read by authenticated users (admin only in practice)
      allow read: if isAuthenticated();

      // Allow create by anyone (doctors and landing page visitors can submit requests)
      allow create: if true;

      // Allow update by authenticated users (for marking as read/resolved)
      allow update: if isAuthenticated();

      // No deletes allowed
      allow delete: if false;
    }

    // ============================================
    // QR CODES COLLECTION
    // ============================================

    match /qrCodes/{qrCode} {
      // Allow anyone to read (for signup validation and QR display)
      allow read: if true;

      // Allow create by anyone (admin generating codes - no auth required for test mode)
      allow create: if true;

      // Allow update during signup or by admin
      allow update: if true;

      // Allow delete by anyone (admin cleanup)
      allow delete: if true;
    }

    // ============================================
    // QR BATCHES COLLECTION
    // ============================================

    match /qrBatches/{batchId} {
      // Allow anyone to read
      allow read: if true;

      // Allow create by anyone (admin generating batches)
      allow create: if true;

      // Allow update by anyone (admin updating batch status)
      allow update: if true;

      // Allow delete by anyone (admin cleanup)
      allow delete: if true;
    }

    // ============================================
    // ASSISTANTS COLLECTION
    // ============================================

    match /assistants/{assistantId} {
      // Allow unauthenticated read when querying by accessToken (for PIN validation)
      // Token acts as authentication (like magic link)
      allow read: if true;

      // Allow doctors to create assistants
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.doctorId;

      // Allow doctors to update their own assistants
      allow update: if isAuthenticated() && request.auth.uid == resource.data.doctorId;

      // Allow updating lastLoginAt without authentication (after PIN validation on client)
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLoginAt']);

      // Allow doctors to delete their own assistants
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.doctorId;
    }

    // ============================================
    // ASSISTANT ACCESS COLLECTION (OLD - DEPRECATED)
    // ============================================

    match /assistantAccess/{accessId} {
      // Allow anyone to query by accessToken (needed for assistant login verification)
      // This is safe because the token is secret and unique
      allow read, list: if true;

      // Allow doctors to create assistant access
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.doctorId;

      // Allow doctors to update/revoke their own assistant access
      allow update: if isAuthenticated() && request.auth.uid == resource.data.doctorId;

      // No deletes allowed (keep history)
      allow delete: if false;
    }

    // ============================================
    // ACTIVATION CODES COLLECTION (QR Pre-Generation - Legacy)
    // ============================================

    match /activationCodes/{qrCode} {
      // Allow anyone to read (for signup validation)
      allow read: if true;

      // Allow create by authenticated users (admin generating codes)
      allow create: if isAuthenticated();

      // Allow update during signup (linking QR to email)
      // Only allow if QR is unused and being linked to authenticated user's email
      allow update: if isAuthenticated() &&
                      (!resource.data.linkedEmail || resource.data.linkedEmail == null) &&
                      request.resource.data.linkedEmail == request.auth.token.email &&
                      request.resource.data.status == 'active';

      // Allow delete by authenticated users (admin only)
      allow delete: if isAuthenticated();
    }

    // ============================================
    // ADVERTISERS COLLECTION
    // ============================================

    match /advertisers/{userId} {
      // Allow read for login/signup email check (no secrets in this collection)
      allow read: if true;
      // Allow create for signup (before auth)
      allow create: if true;
      // Allow update/delete by authenticated users (doc ID is auto-generated, not UID)
      allow update: if isAuthenticated();
      allow delete: if false;

      // ============================================
      // SUPPORT MESSAGES SUBCOLLECTION
      // ============================================
      match /supportMessages/{messageId} {
        allow read, write: if isAuthenticated();
      }
    }

    // ============================================
    // ADVERTISER PROMOS COLLECTION
    // ============================================

    match /advertiserPromos/{promoId} {
      // Allow read by anyone (advertisers need to see it)
      allow read: if true;

      // Allow write by authenticated users (admins)
      allow write: if isAuthenticated();
    }

    // ============================================
    // ADVERTISER CAMPAIGNS
    // ============================================

    match /advertiser_campaigns/{campaignId} {
      allow read: if isAuthenticated() && resource.data.advertiserId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.advertiserId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.advertiserId == request.auth.uid;
    }

    // ============================================
    // REVIEWS COLLECTION
    // ============================================

    match /reviews/{reviewId} {
      // Allow read by anyone (public reviews)
      allow read: if true;

      // Allow create by anyone (patients submitting reviews)
      allow create: if true;

      // Allow update by authenticated users (admin uploads to landing, doctor responds)
      allow update: if isAuthenticated();

      // No deletes
      allow delete: if false;
    }

    // ============================================
    // NOTIFICATION HISTORY COLLECTION
    // ============================================

    match /notificationHistory/{historyId} {
      // Allow read by anyone (doctors and patients can view history)
      // In production, you might want to restrict this to authenticated users only
      allow read: if true;

      // Allow create by anyone (notifications are saved from client & cloud functions)
      allow create: if true;

      // Allow update by system (for marking notifications as read, etc.)
      allow update: if true;

      // Allow delete for cleanup (auto-delete old records)
      allow delete: if true;
    }

    // ============================================
    // PATIENT OTP REQUESTS COLLECTION
    // ============================================

    match /patientOtpRequests/{requestId} {
      // Allow anyone to create OTP requests (patient login flow)
      allow create: if true;

      // Allow read by anyone (to check OTP status)
      allow read: if true;

      // Allow update by Cloud Functions (to mark as sent/failed)
      allow update: if true;

      // Allow delete for cleanup
      allow delete: if true;
    }

    // ============================================
    // COMPANIES COLLECTION (Doctor Company Tracking)
    // ============================================

    match /companies/{companyName} {
      // Allow read by anyone (for analytics/reporting)
      allow read: if true;

      // Allow create by authenticated users during signup
      allow create: if request.auth != null;

      // Allow update to add/remove doctors from company
      allow update: if request.auth != null;

      // No deletes allowed
      allow delete: if false;
    }

    // ============================================
    // PATIENT HEALTH CARDS COLLECTION
    // ============================================

    match /patientHealthCards/{patientPhone} {
      // Allow read by anyone (patients can view their own health card)
      allow read: if true;

      // Allow create/update by anyone (for patient registration)
      allow create, update: if true;

      // Allow delete only by authorized users
      allow delete: if request.auth != null;
    }

    // ============================================
    // QR SCANS COLLECTION
    // ============================================

    match /qrScans/{scanId} {
      // Allow read by:
      // 1. Clinics (to view their own scans)
      // 2. Doctors (to view their own scans)
      // 3. Admin (full access)
      allow read: if isAuthenticated() && (
        (resource.data.scannedBy == 'clinic' && request.auth.uid == resource.data.clinicId) ||
        (resource.data.scannedBy == 'doctor' && request.auth.uid == resource.data.doctorId) ||
        request.auth.token.admin == true
      );

      // Allow list (query) for clinics and doctors to get their scan counts
      allow list: if isAuthenticated() && (
        (request.query.filters.scannedBy == 'clinic') ||
        (request.query.filters.scannedBy == 'doctor') ||
        request.auth.token.admin == true
      );

      // Allow create by anyone (scan tracking happens before auth)
      allow create: if true;

      // Allow update to mark scans as completed
      allow update: if true;

      // No deletes allowed
      allow delete: if false;
    }

    // ============================================
    // BRAINDECK DATA COLLECTION (Quiz tracking)
    // ============================================

    match /brainDeckData/{doctorId} {
      // Allow authenticated doctors to read/write their own quiz data
      allow read, write: if isAuthenticated();
    }

    // ============================================
    // APP CONFIG COLLECTION (Admin-controlled settings)
    // ============================================

    match /appConfig/{configId} {
      // Allow anyone to read (health tip, etc.)
      allow read: if true;
      // Only admin can write (managed via Firebase Console)
      allow write: if isAuthenticated() && request.auth.token.admin == true;
    }

    // ============================================
    // PHARMA COMPANIES COLLECTION
    // ============================================

    match /pharmaCompanies/{companyId} {
      // Public read needed for login verification (email check before auth)
      // Public create needed for signup (before auth)
      // Only authenticated users can update/delete
      allow read: if true;
      allow create: if true;
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /pharmaCompanies/{companyId}/distributedDoctors/{doctorId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /pharmaCompanies/{companyId}/distributedClinics/{clinicId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /pharmaCompanies/{companyId}/supportMessages/{messageId} {
      allow read, write: if isAuthenticated();
    }

    match /pharmaCompanies/{companyId}/promoTemplates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /pharmaCompanies/{companyId}/cmeContent/{contentId} {
      allow read, write: if isAuthenticated();
    }

    match /pharmaCompanies/{companyId}/sampleRequests/{requestId} {
      allow read, write: if isAuthenticated();
    }

    // change requests generated by pharma companies themselves
    match /pharmaChangeRequests/{reqId} {
      // allow anyone to submit a change request (authentication not required)
      allow create: if true;
      // allow authenticated users to view, modify or delete requests (admin panel)
      allow read, list, update, delete: if isAuthenticated();
    }

    // ============================================
    // PHARMA ANALYTICS (PRE-AGGREGATED)
    // ============================================

    match /pharmaAnalytics/{companyId}/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ============================================
    // ADVERTISER ANALYTICS (PINCODE-LEVEL AGGREGATES)
    // ============================================

    match /advertiserAnalytics/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ============================================
    // PAGE DISTRIBUTION (AD SLOT MANAGEMENT)
    // ============================================

    match /pageDistribution/{pageId} {
      // Anyone can read (pages need to render ad slots)
      allow read: if true;
      // Only authenticated users (admin) can write
      allow write: if isAuthenticated();
    }

    // ============================================
    // RX MOLECULE DATA (Anonymous Prescription Analytics)
    // ============================================

    match /rxMoleculeData/{docId} {
      // Authenticated users can read (pharma companies, admin)
      allow read: if isAuthenticated();
      // Authenticated users can create (doctors sending RX)
      allow create: if isAuthenticated();
      // No updates or deletes — immutable analytics data
      allow update, delete: if false;
    }

    // ============================================
    // RX TRENDS (Daily Aggregated Summaries)
    // ============================================

    match /rxTrends/{dateId} {
      // Authenticated users can read (admin, pharma)
      allow read: if isAuthenticated();
      // Only Cloud Functions write (via admin SDK, bypasses rules)
      allow write: if false;
    }

    // ============================================
    // EXTRACTION REQUESTS (Pharma Unlock Requests)
    // ============================================

    match /extractionRequests/{requestId} {
      // Authenticated users can read (pharma + admin)
      allow read: if isAuthenticated();
      // Authenticated users can create (pharma requesting unlock)
      allow create: if isAuthenticated();
      // Authenticated users can update (admin approving/rejecting)
      allow update: if isAuthenticated();
      // No deletes
      allow delete: if false;
    }

    // ============================================
    // PHARMA RX EXTRACTIONS (Subcollection)
    // ============================================

    match /pharmaCompanies/{companyId}/rxExtractions/{extractionId} {
      // Authenticated users can read
      allow read: if isAuthenticated();
      // Authenticated users can create
      allow create: if isAuthenticated();
      // No updates or deletes
      allow update, delete: if false;
    }

    // ============================================
    // PATHOLOGY MOLECULE DATA (Anonymous Lab Data)
    // ============================================

    match /pathologyMoleculeData/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ============================================
    // PATHOLOGY ACCESS REQUESTS
    // ============================================

    match /pathologyAccessRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ============================================
    // RX ACCESS REQUESTS
    // ============================================

    match /rxAccessRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ============================================
    // PHARMA PATHOLOGY EXTRACTIONS (Subcollection)
    // ============================================

    match /pharmaCompanies/{companyId}/pathologyExtractions/{extractionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ============================================
    // PLATFORM HEALTH COLLECTION (Cloud Function writes, Admin reads)
    // ============================================

    match /platform_health/{reportId} {
      allow read: if isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
      allow write: if false; // Only Cloud Functions write
    }

    // ============================================
    // ADMIN ALERTS COLLECTION (Cloud Function creates, Admin reads/resolves)
    // ============================================

    match /admin_alerts/{alertId} {
      allow read: if isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
      allow update: if isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
      allow create, delete: if false; // Only Cloud Functions create
    }

    // ============================================
    // ADMIN CONFIG COLLECTION (Admin read/write for dashboard settings)
    // ============================================

    match /admin_config/{configId} {
      allow read, write: if isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // ============================================
    // DAILY HEALTH REPORTS (Cloud Function writes, Admin reads)
    // ============================================

    match /daily_health_reports/{reportId} {
      allow read: if isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
      allow write: if false; // Only Cloud Functions write
    }

    // ============================================
    // RX EXTRACTION LOGS (Admin tracks who generated reports)
    // ============================================

    match /rxExtractionLogs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ============================================
    // API KEYS (Admin manages, cloud functions validate)
    // ============================================

    match /apiKeys/{keyId} {
      allow read, write: if isAdmin();
    }

    // ============================================
    // REFERRAL LINK SYSTEM
    // ============================================

    // Referral links created by any dashboard user
    match /referralLinks/{linkId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Registered referrers (phone-based auth, NOT Firebase Auth)
    match /referrers/{referrerId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // Referrer booking history (subcollection under referrers)
    match /referrers/{referrerId}/referralHistory/{historyId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // ============================================
    // STAFF MEMBERS COLLECTION
    // ============================================

    match /staffMembers/{staffId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ============================================
    // STAFF ATTENDANCE COLLECTION
    // ============================================

    match /staffAttendance/{recordId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ============================================
    // LEAVE REQUESTS COLLECTION
    // ============================================

    match /leaveRequests/{requestId} {
      allow read: if true;
      allow create: if true;
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ============================================
    // STAFF ROSTERS COLLECTION
    // ============================================

    match /staffRosters/{rosterId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ============================================
    // IVR CODES COLLECTION (IVR booking system for non-smartphone users)
    // ============================================

    match /ivrCodes/{codeId} {
      // Allow read by anyone (IVR system needs to lookup codes)
      allow read: if true;

      // Allow create during signup flow (before and after auth)
      allow create: if true;

      // No updates or deletes (codes are immutable once created)
      allow update, delete: if false;
    }

    // ============================================
    // MEDICAL REPRESENTATIVES (MR) COLLECTION
    // ============================================

    match /medicalReps/{mrId} {
      // Allow read for search and profile loading
      allow read: if true;
      // Allow create during verification flow
      allow create: if isAuthenticated();
      // Allow update/delete only by owner
      allow update, delete: if isOwner(mrId);
    }

    // ============================================
    // PENDING MR SIGNUPS COLLECTION
    // ============================================

    match /pending_mr_signups/{docId} {
      // Allow anyone to create (signup flow before auth)
      allow create: if true;
      // Allow read for verification
      allow read: if true;
      // Allow delete after successful verification
      allow delete: if isAuthenticated();
      // No updates
      allow update: if false;
    }

    // ============================================
    // MR-DOCTOR LINKS COLLECTION
    // ============================================

    match /mrDoctorLinks/{linkId} {
      // Allow read by doctor or MR involved
      allow read: if true;
      // Allow create by anyone (MR sends request)
      allow create: if true;
      // Allow update by doctor or MR involved
      allow update: if true;
      // No deletes
      allow delete: if false;
    }

    // ============================================
    // DEFAULT DENY
    // ============================================

    // Deny access to all other documents
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
